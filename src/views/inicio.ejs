<%- include('partials/header') %>

    <div class="page-wrapper page-wrapper--top">
        <div class="container">
            <div style="margin-bottom: 24px;">
                <h1 class="card__title"
                    style="margin-bottom: 16px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    Solicitações
                </h1>

                <style>
                    /* Classes de estilo para abas dinâmicas */
                    .tab-todos { background: #f0f7ff; color: var(--primary); }
                    .tab-todos.active { background: var(--primary); color: white !important; }
                    
                    .tab-pendente { background: #fffbeb; color: #d97706; }
                    .tab-pendente.active { background: #f59e0b; color: white !important; }
                    
                    .tab-aprovado { background: #ecfdf5; color: #059669; }
                    .tab-aprovado.active { background: #10b981; color: white !important; }
                    
                    .tab-indeferido { background: #fef2f2; color: #dc2626; }
                    .tab-indeferido.active { background: #ef4444; color: white !important; }

                    /* Estilos do filtro especial secundário */
                    .active-special {
                        border-color: var(--primary) !important;
                        background-color: #f0f7ff !important;
                        color: var(--primary) !important;
                        font-weight: 700 !important;
                    }
                </style>
                <!-- Primeira linha de abas: Status -->
                <div style="display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; -webkit-overflow-scrolling: touch; scrollbar-width: none; margin-bottom: 12px;">
                    <a href="/inicio?status=todos" class="list-card__badge tab-todos <%= currentStatus === 'todos' ? 'active' : '' %>"
                        style="cursor: pointer; text-decoration: none; padding: 4px 12px; font-size: 0.85rem; flex-shrink: 0;">
                        Todos (<%= counts.todos %>)
                    </a>

                    <a href="/inicio?status=pendente" class="list-card__badge tab-pendente <%= currentStatus === 'pendente' ? 'active' : '' %>"
                        style="cursor: pointer; text-decoration: none; padding: 4px 12px; font-size: 0.85rem; flex-shrink: 0;">
                        <span
                            style="width: 6px; height: 6px; border-radius: 50%; background-color: currentColor; display: inline-block; flex-shrink: 0;"></span>
                        Pendente (<%= counts.pendente %>)
                    </a>

                    <a href="/inicio?status=aprovado" class="list-card__badge tab-aprovado <%= currentStatus === 'aprovado' ? 'active' : '' %>"
                        style="cursor: pointer; text-decoration: none; padding: 4px 12px; font-size: 0.85rem; flex-shrink: 0;">
                        <span
                            style="width: 6px; height: 6px; border-radius: 50%; background-color: currentColor; display: inline-block; flex-shrink: 0;"></span>
                        Aprovado (<%= counts.aprovado %>)
                    </a>

                    <a href="/inicio?status=indeferido" class="list-card__badge tab-indeferido <%= currentStatus === 'indeferido' ? 'active' : '' %>"
                        style="cursor: pointer; text-decoration: none; padding: 4px 12px; font-size: 0.85rem; flex-shrink: 0;">
                        <span
                            style="width: 6px; height: 6px; border-radius: 50%; background-color: currentColor; display: inline-block; flex-shrink: 0;"></span>
                        Indeferido (<%= counts.indeferido %>)
                    </a>
                </div>

                <!-- Segunda linha de filtros: PCD e Idoso (Vagas Especiais) -->
                <div style="display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; -webkit-overflow-scrolling: touch; scrollbar-width: none; margin-bottom: 12px; align-items: center;">
                    <button type="button" onclick="toggleSpecialFilter('pcd', this)" class="special-filter-btn" style="cursor: pointer; padding: 3px 10px; font-size: 0.78rem; border-radius: 99px; border: 1.5px solid #cbd5e1; background: white; color: #475569; font-weight: 500; outline: none; transition: all 0.2s;">
                        PCD
                    </button>
                    
                    <button type="button" onclick="toggleSpecialFilter('idoso', this)" class="special-filter-btn" style="cursor: pointer; padding: 3px 10px; font-size: 0.78rem; border-radius: 99px; border: 1.5px solid #cbd5e1; background: white; color: #475569; font-weight: 500; outline: none; transition: all 0.2s;">
                        Idoso
                    </button>
                </div>

                <!-- Barra de Busca -->
                <div style="position: relative; margin-top: 16px; margin-bottom: 8px;">
                    <div style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; pointer-events: none;">
                        <i data-lucide="search" style="width: 18px; height: 18px;"></i>
                    </div>
                    <input type="text" id="search-input" placeholder="Buscar por colaborador ou placa..." 
                        style="width: 100%; padding: 10px 16px 10px 42px; border: 1.5px solid #cbd5e1; border-radius: 99px; font-size: 0.95rem; outline: none; transition: border-color 0.2s;"
                        oninput="filterVehicles(this.value)">
                </div>
            </div>

            <% if (vehicles && vehicles.length> 0) { %>
                <style>
                    /* Aprovado (Verde) */
                    .list-card.list-card--active { border-left-color: #10b981; }
                    .list-card__badge.list-card__badge--active { background-color: #ecfdf5; color: #059669; }
                    
                    /* Pendente (Amarelo) */
                    .list-card.list-card--future { border-left-color: #f59e0b; }
                    .list-card__badge.list-card__badge--future { background-color: #fffbeb; color: #d97706; }
                    
                    /* Indeferido (Vermelho) */
                    .list-card.list-card--expired { border-left-color: #ef4444; }
                    .list-card__badge.list-card__badge--expired { background-color: #fef2f2; color: #dc2626; }
                </style>
                <div class="list-grid">
                    <% vehicles.forEach(v=> {
                        let statusClass = v.status === 'aprovado' ? 'active' : (v.status === 'pendente' ? 'future' :
                        'expired');
                        let statusLabel = v.status === 'aprovado' ? 'Aprovado' : (v.status === 'pendente' ? 'Pendente' :
                        'Indeferido');

                        let imgSrc = 'outro.png';
                        if(v.vehicle_type === 'Carro') imgSrc = 'carro.png';
                        if(v.vehicle_type === 'Moto') imgSrc = 'moto.png';
                        %>
                        <div class="list-card list-card--<%= statusClass %> vehicle-item" style="cursor: pointer;"
                            data-name="<%= v.full_name.toLowerCase() %>"
                            data-plate="<%= v.plate.toLowerCase() %>"
                            data-pcd="<%= v.is_pcd ? '1' : '0' %>"
                            data-elderly="<%= v.is_elderly ? '1' : '0' %>"
                            data-special="<%= v.needs_special_spot ? '1' : '0' %>"
                            onclick="window.location.href='/inicio/analisar/<%= v.id %>'">
                            <img src="/images/<%= imgSrc %>" alt="<%= v.vehicle_type %>"
                                style="width: 42px; height: 42px; object-fit: contain; flex-shrink: 0;">
                            <div class="list-card__info">
                                <div class="list-card__title">
                                    <%= v.full_name %>
                                </div>
                                <div class="list-card__meta"
                                    style="flex-wrap: nowrap; gap: 8px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
                                    <span>
                                        <%= v.brand %>
                                            <%= v.model %>
                                    </span>
                                    <span style="color: var(--border)">&bull;</span>
                                    <span style="display: inline-flex; align-items: center; gap: 4px;"><i
                                            data-lucide="calendar" class="w-3.5 h-3.5"></i>
                                        <%= new Date(v.created_at).toLocaleDateString('pt-BR') %>
                                    </span>
                                </div>
                            </div>
                            <div class="list-card__actions" style="display: flex; align-items: center; gap: 12px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <span class="list-card__badge list-card__badge--<%= statusClass %>">
                                        <span
                                            style="width: 8px; height: 8px; border-radius: 50%; background-color: currentColor; display: inline-block; flex-shrink: 0;"></span>
                                        <%= statusLabel %>
                                    </span>
                                    <span
                                        style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.85rem; color: var(--text-muted); font-weight: 500; text-transform: uppercase;">
                                        Placa: <%= v.plate %>
                                    </span>
                                </div>
                                <% if (v.status==='aprovado' ) { %>
                                    <div class="list-card__count" style="background: var(--primary); border-radius: 99px; padding: 4px 12px; height: auto;">
                                        <a href="/inicio/pdf/<%= v.id %>" target="_blank"
                                            style="color: white; font-size: 0.8rem; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;"
                                            onclick="event.stopPropagation();"><i data-lucide="download" class="w-3 h-3"></i> PDF</a>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <div class="empty-state" style="text-align: center; padding: 3rem 1rem;">
                        <p class="empty-state__text">Nenhuma solicitação encontrada.</p>
                    </div>
                    <% } %>
        </div>
    </div>

    <script>
        let activeSpecialFilter = 'todos';
        let activeSearchQuery = '';

        function filterVehicles(query) {
            activeSearchQuery = query.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
            applyFilters();
        }

        function toggleSpecialFilter(filterType, button) {
            if (activeSpecialFilter === filterType) {
                activeSpecialFilter = 'todos';
                button.classList.remove('active-special');
            } else {
                document.querySelectorAll('.special-filter-btn').forEach(btn => {
                    btn.classList.remove('active-special');
                });
                activeSpecialFilter = filterType;
                button.classList.add('active-special');
            }
            applyFilters();
        }

        function applyFilters() {
            const items = document.querySelectorAll('.vehicle-item');
            let countVisible = 0;
            
            items.forEach(item => {
                const name = item.getAttribute('data-name').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                const plate = item.getAttribute('data-plate');
                const isPcd = item.getAttribute('data-pcd') === '1';
                const isElderly = item.getAttribute('data-elderly') === '1';
                const needsSpecial = item.getAttribute('data-special') === '1';
                
                // Verificar busca por texto
                const matchesSearch = name.includes(activeSearchQuery) || plate.includes(activeSearchQuery);
                
                // Verificar filtro especial secundário
                let matchesSpecial = true;
                if (activeSpecialFilter === 'pcd') {
                    matchesSpecial = isPcd;
                } else if (activeSpecialFilter === 'idoso') {
                    matchesSpecial = isElderly;
                } else if (activeSpecialFilter === 'vaga') {
                    matchesSpecial = needsSpecial;
                }
                
                if (matchesSearch && matchesSpecial) {
                    item.style.display = 'flex';
                    countVisible++;
                } else {
                    item.style.display = 'none';
                }
            });

            // Tratamento de estado vazio para busca/filtros combinados
            let emptyState = document.getElementById('search-empty-state');
            if (countVisible === 0) {
                if (!emptyState) {
                    emptyState = document.createElement('div');
                    emptyState.id = 'search-empty-state';
                    emptyState.className = 'empty-state';
                    emptyState.style.textAlign = 'center';
                    emptyState.style.padding = '3rem 1rem';
                    emptyState.innerHTML = '<p class="empty-state__text">Nenhuma solicitação corresponde aos filtros aplicados.</p>';
                    const listGrid = document.querySelector('.list-grid');
                    if (listGrid) {
                        listGrid.style.display = 'none';
                        listGrid.parentNode.appendChild(emptyState);
                    }
                } else {
                    emptyState.style.display = 'block';
                    const listGrid = document.querySelector('.list-grid');
                    if (listGrid) listGrid.style.display = 'none';
                }
            } else {
                if (emptyState) emptyState.style.display = 'none';
                const listGrid = document.querySelector('.list-grid');
                if (listGrid) listGrid.style.display = 'grid';
            }
        }
    </script>

    <%- include('partials/footer') %>